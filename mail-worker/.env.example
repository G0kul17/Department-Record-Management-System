NODE_ENV=production

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Same database as the main backend — mail-worker reads from mail_queue.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=drms_db
DB_USER=postgres
DB_PASS=your_secure_password_here

# ─── Postfix SMTP relay ───────────────────────────────────────────────────────
# Internal relay running on a separate server.
# For a local/trusted relay, auth is usually not required (leave SMTP_RELAY_USER blank).
SMTP_RELAY_HOST=your-postfix-server
SMTP_RELAY_PORT=25
SMTP_RELAY_FROM=noreply@yourdomain.com

# Optional SASL credentials — only needed if your Postfix relay requires auth:
# SMTP_RELAY_USER=
# SMTP_RELAY_PASS=

# ─── Dispatcher tuning ───────────────────────────────────────────────────────
# How often (ms) the worker checks mail_queue for pending jobs.
POLL_INTERVAL_MS=5000
# How many times to retry a failed send before marking it permanently failed.
MAX_ATTEMPTS=3

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# SERVICE_NAME=drms-mail-worker
