NODE_ENV=production

# ─── Server ───────────────────────────────────────────────────────────────────
MAIL_WORKER_PORT=3001

# Shared secret — the main backend sends this as "Authorization: Bearer <secret>".
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MAIL_WORKER_SECRET=change_me_to_a_long_random_secret

# ─── SMTP ─────────────────────────────────────────────────────────────────────
# Same options as the original backend mailer — Gmail service or custom SMTP host.

# Option A: Custom SMTP host (Outlook, SendGrid, etc.)
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your_app_password

# Option B: Gmail with App Password (comment out the host/port lines above and
# uncomment this):
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_PASS=your_gmail_app_password

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# SERVICE_NAME=drms-mail-worker
